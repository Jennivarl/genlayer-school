NEXT_PUBLIC_APP_URL=http://localhost:3100

# Privy auth
NEXT_PUBLIC_PRIVY_APP_ID=
NEXT_PUBLIC_PRIVY_CLIENT_ID=
PRIVY_APP_ID=
PRIVY_VERIFICATION_KEY=
PRIVY_AUTH_REQUIRED=false

# Backend storage driver: local | supabase | auto
GENLAYER_SCHOOL_STORAGE_DRIVER=auto

# Required only when GENLAYER_SCHOOL_STORAGE_DRIVER=supabase or when using auto with Supabase enabled.
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Later: GenLayer RPC and certificate contract settings.
GENLAYER_RPC_URL=
GENLAYER_CERTIFICATE_ISSUER_ADDRESS=
