{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "baseUrl": ".",
    "paths": {
      "@genlayer-school/content": ["packages/content/src"],
      "@genlayer-school/content/*": ["packages/content/src/*"],
      "@genlayer-school/sdk": ["packages/sdk/src"],
      "@genlayer-school/sdk/*": ["packages/sdk/src/*"],
      "@genlayer-school/ui": ["packages/ui/src"],
      "@genlayer-school/ui/*": ["packages/ui/src/*"]
    }
  }
}
